# Orchestral Machine — environment configuration
# Copy to .env and fill in your own values. Never commit .env.

# OpenRouter API key (required) — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Telegram operator bot (optional — only needed for the Telegram control channel)
TELEGRAM_BOT_TOKEN=
# Chat ID the bot sends notifications to
TELEGRAM_CHAT_ID=
# Comma-separated Telegram user IDs allowed to issue operator commands
ALLOWED_TELEGRAM_USERS=

# API key protecting the REST control endpoints (/control/*)
CONTROL_API_KEY=

# Runtime environment: development | production
ORCHESTRAL_ENV=development
